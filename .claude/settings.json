{
  "permissions": {
    "allow": [
      "Write",
      "Edit",
      "Bash",
      "PowerShell",
      "Read",
      "Glob",
      "Grep",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "Bash(powershell -Command \"& '.\\\\bin\\\\python.ps1' 'src\\\\api\\\\ceic_client.py' search 'GDP' --limit 5\")",
      "PowerShell(Get-ExecutionPolicy -List)",
      "PowerShell(& '.\\\\bin\\\\python.ps1' 'src\\\\api\\\\ceic_client.py' search 'GDP' --limit 5)",
      "PowerShell(.\\\\setup.ps1)",
      "PowerShell(py --list 2>&1)",
      "PowerShell(py --version 2>&1)",
      "PowerShell(py install 3.12)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NonInteractive -Command \"if (Test-Path 'bin\\python.ps1') { & 'bin\\python.ps1' 'src/utils/clean_temp.py' 2>$null }\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "powershell.exe -NonInteractive -Command \"(New-Object Media.SoundPlayer 'C:\\Windows\\Media\\Windows Notify System Generic.wav').PlaySync()\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
