{
  "permissions": {
    "allow": [
      "Write",
      "Edit",
      "Bash",
      "PowerShell",
      "Read",
      "Glob",
      "Grep",
      "NotebookEdit",
      "WebFetch",
      "WebSearch"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NonInteractive -Command \"if (Test-Path 'bin\\python.ps1') { & 'bin\\python.ps1' 'src/utils/clean_temp.py' 2>$null }\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "powershell.exe -NonInteractive -Command \"(New-Object Media.SoundPlayer 'C:\\Windows\\Media\\Windows Notify System Generic.wav').PlaySync()\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
