# Workspace Environment Configuration Template (.env.example)
#
# INSTRUCTIONS:
# 1. Copy this file and rename it to `.env` in the project root directory.
# 2. Fill in your personal API keys and database credentials below.
# 3. Ensure `.env` is listed in your `.gitignore` to protect sensitive keys.

# ==============================================================================
# 1. CEIC Database Access
# ==============================================================================
# CEIC is a global economic database. Access requires active credentials.
# Obtain access from: https://www.ceicdata.com/
CEIC_USERNAME=your_username@domain.com
CEIC_PASSWORD=your_secure_password
CEIC_API_KEY=your_long_ceic_api_token_here

# ==============================================================================
# 2. Bank of Thailand (BOT) API Access
# ==============================================================================
# BOT provides national banking, financial, and macroeconomic indicator series.
# Register and subscribe to APIs at: https://iapi.bot.or.th/
# Token is usually an encrypted JSON or JWT signature (e.g. eyJvcmciOiI2NzM1...)
BOT_API_TOKEN=your_bot_api_token_here

# ==============================================================================
# 3. U.S. Energy Information Administration (EIA) API v2 Access
# ==============================================================================
# EIA provides international and U.S. energy production, consumption, and price data.
# Register and request a free API key at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_40_character_eia_api_key_here

# ==============================================================================
# 4. IMF Developer API Access
# ==============================================================================
# IMF provides global macroeconomic and financial statistics (WEO, IFS, BOP, CPI).
# Register and subscribe to the API at the IMF Data Portal/Developer Portal.
# Auth is passed via the subscription key header.
IMF_API_KEY=your_32_character_imf_api_key_here

# ==============================================================================
# 5. NESDC Social Data Portal (socdata.nesdc.go.th)
# ==============================================================================
# NESDC's provincial social indicator database (77 provinces × 29 indicators).
# Obtain API key from NESDC's data team.
SOCDATA_API_KEY=your_socdata_api_key_here
